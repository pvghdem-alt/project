rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // DiscussionNote Validation
    function isValidNote(data) {
      return data.floor in ['B3F', 'B5F'] &&
             data.space is string && data.space.size() > 0 && data.space.size() <= 100 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
             data.status in ['pending', 'confirmed'];
    }

    match /notes/{noteId} {
      allow list: if true;
      allow get: if true;
      allow create: if isValidId(noteId) && isValidNote(incoming());
      allow update: if isValidNote(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['content', 'status'])
      );
      allow delete: if true;
    }

    // CustomTopic Validation
    function isValidTopic(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 50;
    }

    match /topics/{topicId} {
      allow read: if true;
      allow list: if true;
      allow create: if isValidId(topicId) && isValidTopic(incoming());
      allow delete: if true;
    }

    match /maps/{mapId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /requirements/{reqId} {
      allow read: if true;
      allow write: if true;
    }

    match /checklist/{checkId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
